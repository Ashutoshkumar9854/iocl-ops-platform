# IOCL Backend – Environment Variables
# Copy this file to .env and fill in values

# Database file path (set to Render persistent disk mount path in production)
# Example: /var/data/iocl_operations.db
DB_PATH=

# Port the server listens on (Render sets this automatically)
PORT=3001

# The public URL of the deployed frontend (used to restrict CORS)
# Example: https://iocl-ops.vercel.app
FRONTEND_URL=

# Node environment
NODE_ENV=production
