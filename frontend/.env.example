# IOCL Frontend – Environment Variables
# Copy this file to .env and fill in the values.
# On Vercel, set these as Environment Variables in the project settings.

# The public URL of your deployed backend API (from Render)
# Example: https://iocl-backend.onrender.com/api/v1
VITE_API_BASE_URL=

# The public WebSocket URL of your deployed backend (from Render)
# Example: wss://iocl-backend.onrender.com
VITE_WS_URL=
